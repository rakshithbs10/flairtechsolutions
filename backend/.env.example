# ─── Azure SQL Database ────────────────────────────────────────────────────────
AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=flairtechdb
AZURE_SQL_USER=sqladmin
AZURE_SQL_PASSWORD=YourStrongPassword123!
AZURE_SQL_PORT=1433

# ─── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=resumes

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── App Config ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
FRONTEND_URL=https://your-app-name.azurewebsites.net
